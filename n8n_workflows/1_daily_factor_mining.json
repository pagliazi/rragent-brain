    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:7789/api/n8n/trigger/mine",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-N8n-Token",  "value": "openclaw-n8n-2026" },
            { "name": "Content-Type", "value": "application/json"  }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => { const h = $now.hour; const m = $now.minute; const isPreOpen   = (h === 9  && m <= 25); const isOpen      = (h === 9  && m >= 30 && m < 55); const isMorningHot= (h === 9  && m >= 50) || (h === 10 && m <= 30); const isMorning   = (h >= 10 && m > 30 && h < 11); const isLunch     = (h === 11 && m >= 30) || (h === 12); const isAfternoonOpen = (h === 13 && m < 40); const isAfternoon = (h >= 13 && h < 15); const isClose     = (h === 15); const isEvening   = (h >= 20); const session = isPreOpen ? 'pre_open' : isOpen ? 'open_auction' : isMorningHot ? 'morning_hot' : isMorning ? 'morning_session' : isLunch ? 'lunch_break' : isAfternoonOpen ? 'afternoon_open' : isAfternoon ? 'afternoon_session' : isClose ? 'closing' : isEvening ? 'evening_review' : 'overnight'; const isHotPeriod = isOpen || isMorningHot || isAfternoonOpen; const rounds = isHotPeriod ? 3 : isEvening ? 5 : 2; const fpr = isHotPeriod ? 5 : isEvening ? 5 : 5; return JSON.stringify({ rounds, factors_per_round: fpr, timeframes: ['10s', '15s', '30s', '1min', '2min', '3min', '5min'], focus: 'ultra_short', intraday_only: true, session_tag: session, ultra_short_weight: 2.5 }); })() }}"
      },
