    {
      "parameters": {
        "jsCode": "const status = $input.first().json;\nconst stats = status.factor_stats || {};\nconst events = status.recent_events || [];\n\nconst ultraShortEvent = events.find(e => e.type === 'mine_session_done' && e.focus === 'ultra_short');\nconst mineEvent = events.find(e => e.type === 'mine_session_done' && e.focus === 'short_term');\nconst smartEvent = events.find(e => e.type === 'combine_smart_done');\nconst exhaustEvent = events.find(e => e.type === 'combine_all_done');\nconst promoteEvent = events.find(e => e.type === 'auto_promote_done');\n\nlet msg = `⚡ rragents 超短线因子管线报告\\n`;\nmsg += `${new Date().toLocaleDateString()} ${new Date().toLocaleTimeString()}\\n`;\nmsg += `━━━━━━━━━━━━━━━━━━\\n`;\nmsg += `📦 活跃因子: ${stats.active_count || 0} 个\\n`;\nmsg += `🏆 最佳 Sharpe: ${(stats.best_sharpe || 0).toFixed(3)}\\n`;\nmsg += `📊 平均 Sharpe: ${(stats.avg_sharpe || 0).toFixed(3)}\\n`;\n\nif (ultraShortEvent?.result) {\n  const r = ultraShortEvent.result;\n  msg += `\\n⚡ 超短线(10s-5min): 生成 ${r.total_generated} → 测试 ${r.total_tested} → 入库 ${r.total_admitted}\\n`;\n  if (r.top_factors && r.top_factors.length) {\n    msg += `  最优: ${r.top_factors.slice(0,3).map(f => `${f.name}[${f.timeframe||'?'}](Sharpe=${(f.sharpe||0).toFixed(2)})`).join(', ')}\\n`;\n  }\n}\n\nif (mineEvent?.result) {\n  const r = mineEvent.result;\n  msg += `\\n⛏️ 短线补充(5-30min): 生成 ${r.total_generated} → 测试 ${r.total_tested} → 入库 ${r.total_admitted}\\n`;\n}\n\nif (smartEvent) {\n  msg += `\\n🎯 智能融合: 跨主题 ${smartEvent.smart_count || 0} + 贪心 ${smartEvent.greedy_count || 0} → 通过 ${smartEvent.accepted}\\n`;\n}\n\nif (exhaustEvent) {\n  msg += `🔮 穷举融合: 测试 ${exhaustEvent.tested} → 通过 ${exhaustEvent.accepted}\\n`;\n}\n\nif (promoteEvent && promoteEvent.promoted > 0) {\n  msg += `\\n📈 自动策略化: ${promoteEvent.promoted} 个新策略已推送\\n`;\n  (promoteEvent.strategies || []).forEach((s, i) => {\n    msg += `  ${i+1}. [${s.theme}|${s.timeframe||'?'}] Sharpe=${(s.sharpe||0).toFixed(2)} ${s.quality_grade}\\n`;\n  });\n}\n\nconst ultraShortCount = stats.ultra_short_count || 0;\nconst totalCount = stats.active_count || 1;\nmsg += `\\n📋 超短线占比: ${ultraShortCount}/${totalCount} (${Math.round(ultraShortCount/totalCount*100)}%)`;\n\nconst themes = stats.theme_distribution || {};\nconst top5 = Object.entries(themes).sort((a,b) => b[1]-a[1]).slice(0,5);\nif (top5.length) {\n  msg += `\\n主题: ${top5.map(([k,v]) => `${k}(${v})`).join(' | ')}`;\n}\n\nreturn [{json: {message: msg}}];"
      },
