# ── gen-plists: 从 registry 生成 LaunchAgent plists ─
# 内部函数，生成 plist 文件到对应用户的 LaunchAgents 目录
_gen_plists() {
    mkdir -p "${LA_DIR}"
    sudo mkdir -p "${CLAW_LA_DIR}" "${CLAW_LOGS}" 2>/dev/null || true
    sudo chown ${CLAW_USER}:staff "${CLAW_LA_DIR}" "${CLAW_LOGS}" 2>/dev/null || true

    local zayl_count=0
    local claw_count=0

    while IFS=$'\t' read -r name type target env label auto run_as; do
        : ${run_as:=clawagent}
        local plist_label="com.openclaw.${label:-$name}"

        local work_dir venv_path log_dir plist_dir
        if [ "$run_as" = "zayl" ]; then
            work_dir="${SCRIPT_DIR}"
            venv_path="${VENV}"
            log_dir="${LOGS_DIR}"
            plist_dir="${LA_DIR}"
            zayl_count=$((zayl_count + 1))
        else
            work_dir="${CLAW_DIR}"
            venv_path="${CLAW_VENV}"
            log_dir="${CLAW_LOGS}"
            plist_dir="${CLAW_LA_DIR}"
            claw_count=$((claw_count + 1))
        fi

        local plist_file="${plist_dir}/${plist_label}.plist"
        local logfile="${log_dir}/${label:-$name}.log"
        local errfile="${log_dir}/${label:-$name}.err"

        local env_source_snippet=""
        if [ -n "$env" ] && [ "$env" != "-" ]; then
            env_source_snippet="
        <key>ENV_FILE</key>
        <string>${work_dir}/${env}</string>"
        fi

        if [ "$type" = "agent" ]; then
            local plist_content="<?xml version=\"1.0\" encoding=\"UTF-8\"?>
<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">
<plist version=\"1.0\">
<dict>
    <key>Label</key>
    <string>${plist_label}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${venv_path}/bin/python</string>
        <string>-m</string>
        <string>${target}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${work_dir}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${logfile}</string>
    <key>StandardErrorPath</key>
    <string>${errfile}</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>PYTHONPATH</key>
        <string>${work_dir}</string>
        <key>REDIS_URL</key>
        <string>redis://127.0.0.1:6379/0</string>${env_source_snippet}
    </dict>
</dict>
</plist>"
        else
            local plist_content="<?xml version=\"1.0\" encoding=\"UTF-8\"?>
<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">
<plist version=\"1.0\">
<dict>
    <key>Label</key>
    <string>${plist_label}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${venv_path}/bin/python</string>
        <string>${work_dir}/${target}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${work_dir}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <key>StandardOutPath</key>
    <string>${logfile}</string>
    <key>StandardErrorPath</key>
    <string>${errfile}</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${venv_path}/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>PYTHONPATH</key>
        <string>${work_dir}</string>
        <key>REDIS_URL</key>
        <string>redis://127.0.0.1:6379/0</string>${env_source_snippet}
    </dict>
</dict>
</plist>"
        fi

        if [ "$run_as" = "zayl" ]; then
            echo "$plist_content" > "${plist_file}"
        else
            echo "$plist_content" | sudo tee "${plist_file}" > /dev/null
            sudo chown ${CLAW_USER}:staff "${plist_file}"
        fi
        echo -e "  ${GREEN}✓${NC} ${plist_file} ${DIM}(${run_as})${NC}"
    done < <(_parse_registry)

    echo ""
    echo -e "  zayl: ${zayl_count} 个 → ${LA_DIR}/"
    echo -e "  clawagent: ${claw_count} 个 → ${CLAW_LA_DIR}/"
}

# ── install: 生成 plists + launchctl 加载全部组件 ──
cmd_install() {
    echo -e "${CYAN}安装 LaunchAgent 服务 (从 registry.yaml 生成 + 加载)...${NC}"
    echo ""

    # 1. 生成 plist
    _gen_plists

    echo ""
    echo -e "${CYAN}加载 LaunchAgent 服务...${NC}"

    # 2. launchctl bootstrap
    local zayl_uid=$(id -u)
    local claw_uid=$(id -u ${CLAW_USER} 2>/dev/null || echo "503")

    while IFS=$'\t' read -r name type target env label auto run_as; do
        : ${run_as:=clawagent}
        local plist_label="com.openclaw.${label:-$name}"

        if [ "$run_as" = "zayl" ]; then
            local plist_file="${LA_DIR}/${plist_label}.plist"
            launchctl bootout "gui/${zayl_uid}/${plist_label}" 2>/dev/null || true
            if launchctl bootstrap "gui/${zayl_uid}" "$plist_file" 2>/dev/null; then
                echo -e "  ${GREEN}✓${NC} ${name} (launchd, zayl)"
            else
                echo -e "  ${RED}✗${NC} ${name} 加载失败"
            fi
        else
            local plist_file="${CLAW_LA_DIR}/${plist_label}.plist"
            sudo launchctl bootout "gui/${claw_uid}/${plist_label}" 2>/dev/null || true
            if sudo launchctl bootstrap "gui/${claw_uid}" "$plist_file" 2>/dev/null; then
                echo -e "  ${GREEN}✓${NC} ${name} (launchd, ${CLAW_USER})"
            else
                echo -e "  ${RED}✗${NC} ${name} 加载失败"
            fi
        fi
    done < <(_parse_registry)

    echo ""
    echo -e "${GREEN}安装完成 — 所有组件已注册为 LaunchAgent 服务${NC}"
    echo -e "${DIM}开机自动启动 (RunAtLoad + KeepAlive)${NC}"
    echo -e "${DIM}查看状态: rrclaw status${NC}"
}

# ── uninstall: 卸载全部 LaunchAgent 服务 ─────────
cmd_uninstall() {
    echo -e "${CYAN}卸载 LaunchAgent 服务...${NC}"

    local zayl_uid=$(id -u)
    local claw_uid=$(id -u ${CLAW_USER} 2>/dev/null || echo "503")

    while IFS=$'\t' read -r name type target env label auto run_as; do
        : ${run_as:=clawagent}
        local plist_label="com.openclaw.${label:-$name}"

        if [ "$run_as" = "zayl" ]; then
            local plist_file="${LA_DIR}/${plist_label}.plist"
            launchctl bootout "gui/${zayl_uid}/${plist_label}" 2>/dev/null || true
            rm -f "$plist_file"
            echo -e "  ${GREEN}✓${NC} ${name} 已卸载 (zayl)"
        else
            local plist_file="${CLAW_LA_DIR}/${plist_label}.plist"
            sudo launchctl bootout "gui/${claw_uid}/${plist_label}" 2>/dev/null || true
            sudo rm -f "$plist_file"
            echo -e "  ${GREEN}✓${NC} ${name} 已卸载 (${CLAW_USER})"
        fi
    done < <(_parse_registry)

    echo ""
    echo -e "${GREEN}卸载完成 — 所有 LaunchAgent plist 已移除${NC}"
}

# ── deploy: 同步 clawagent 组件到 clawagent 目录 ──
cmd_deploy() {
    if [ ! -d "${CLAW_DIR}" ]; then
        echo -e "${YELLOW}目标目录不存在: ${CLAW_DIR}${NC}"
        echo "创建: sudo mkdir -p ${CLAW_DIR}/agents/{souls,skills,memory,data_sources} ${CLAW_LOGS}"
        return 1
    fi

    echo -e "${CYAN}同步 clawagent 组件代码到 ${CLAW_DIR}...${NC}"
    echo -e "${DIM}(仅同步 run_as=clawagent 的组件所需文件)${NC}"

    sudo cp "${SCRIPT_DIR}/agents/"*.py "${CLAW_DIR}/agents/"
    sudo cp -r "${SCRIPT_DIR}/agents/memory/" "${CLAW_DIR}/agents/memory/" 2>/dev/null || true
    sudo cp -r "${SCRIPT_DIR}/agents/data_sources/" "${CLAW_DIR}/agents/data_sources/" 2>/dev/null || true
    sudo cp "${SCRIPT_DIR}/agents/souls/"*.md "${CLAW_DIR}/agents/souls/" 2>/dev/null || true
    sudo cp "${SCRIPT_DIR}/agents/skills/"*.yaml "${CLAW_DIR}/agents/skills/" 2>/dev/null || true

    sudo cp "${SCRIPT_DIR}/telegram_bot.py" "${CLAW_DIR}/"
    sudo cp "${SCRIPT_DIR}/feishu_bot.py" "${CLAW_DIR}/"
    sudo cp "${SCRIPT_DIR}/webchat_api.py" "${CLAW_DIR}/"
    sudo cp "${SCRIPT_DIR}/webchat_frontend.html" "${CLAW_DIR}/"
    sudo cp "${SCRIPT_DIR}/rules.yaml" "${CLAW_DIR}/" 2>/dev/null || true
    sudo cp "${SCRIPT_DIR}/registry.yaml" "${CLAW_DIR}/" 2>/dev/null || true

    for envf in telegram.env feishu.env webchat.env .env; do
        if [ -f "${SCRIPT_DIR}/${envf}" ]; then
            sudo cp "${SCRIPT_DIR}/${envf}" "${CLAW_DIR}/" 2>/dev/null || true
        fi
    done

    sudo find "${CLAW_DIR}" -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
    sudo chown -R ${CLAW_USER}:staff "${CLAW_DIR}"

    echo -e "${GREEN}✓ clawagent 代码已同步${NC}"
    echo ""
    echo -e "${DIM}zayl 用户组件 (apple/desktop/browser/dev) 直接运行于 ${SCRIPT_DIR}，无需同步${NC}"
    echo -e "${DIM}运行 'rrclaw restart all' 使变更生效${NC}"
}

