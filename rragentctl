# ── 入口 ──────────────────────────────────────────
case "${1:-help}" in
    status)         cmd_status ;;
    heartbeat|hb)   cmd_heartbeat ;;
    logs|log)       cmd_logs "${2}" "${3}" ;;
    follow|f)       cmd_follow "${2}" ;;
    start)          cmd_start "${2}" ;;
    stop)           cmd_stop "${2}" ;;
    restart)        cmd_restart "${2}" ;;
    dev)            cmd_dev "${2}" ;;
    deploy)         cmd_deploy ;;
    install)        cmd_install ;;
    uninstall)      cmd_uninstall ;;
    gen-plists)     _gen_plists ;;  # 兼容旧命令，静默生成
    redis)          cmd_redis "${2}" ;;
    test)           cmd_test "${2}" "${3}" "${4}" ;;
    souls)          cmd_souls ;;
    help|--help|-h) cmd_help ;;
    *)
        echo -e "${RED}未知命令: ${1}${NC}"
        cmd_help
        exit 1
        ;;
esac
